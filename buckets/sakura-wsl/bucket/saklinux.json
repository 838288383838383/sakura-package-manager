{
    "name": "saklinux",
    "version": "1.0.0",
    "description": "SakLinux - Sakura's Subsystem for Linux. Your own custom Linux environment.",
    "homepage": "https://github.com/838288383838383/sakura-package-manager",
    "license": "MIT",
    "url": "https://github.com/838288383838383/saklinux/releases/download/v1.0.0/saklinux-rootfs.tar.gz",
    "hash": "",
    "nonportable": true,
    "wsl": true,
    "wsl_name": "SakLinux",
    "wsl_version": 2,
    "suggest": {
        "neovim": "Sakura-themed editor",
        "lazyvim": "Neovim config for SakLinux"
    },
    "setup_prompts": [
        {
            "id": "install_wsl",
            "question": "Install SakLinux within WSL2? (your own subsystem)",
            "type": "yesno",
            "default": "yes"
        },
        {
            "id": "desktop",
            "question": "Which desktop environment? (can add later)",
            "type": "choice",
            "default": "1",
            "options": [
                { "label": "None (headless)", "value": "none", "description": "Minimal, terminal only - recommended" },
                { "label": "GNOME", "value": "gnome", "description": "Full desktop (large download)" },
                { "label": "KDE Plasma", "value": "kde", "description": "Customizable desktop (large download)" },
                { "label": "XFCE", "value": "xfce", "description": "Lightweight desktop" }
            ]
        },
        {
            "id": "install_sakura_pkg",
            "question": "Install Sakura package manager inside SakLinux?",
            "type": "yesno",
            "default": "yes"
        },
        {
            "id": "default_shell",
            "question": "Default shell?",
            "type": "choice",
            "default": "1",
            "options": [
                { "label": "Bash", "value": "bash", "description": "Standard, reliable" },
                { "label": "Zsh", "value": "zsh", "description": "With plugins and themes" },
                { "label": "Fish", "value": "fish", "description": "User-friendly, autosuggestions" }
            ]
        },
        {
            "id": "install_languages",
            "question": "Pre-install programming languages?",
            "type": "choice",
            "default": "5",
            "options": [
                { "label": "None", "value": "none", "description": "Install later with sak" },
                { "label": "Node.js only", "value": "node", "description": "JavaScript/TypeScript" },
                { "label": "Python only", "value": "python", "description": "Python 3 + pip" },
                { "label": "Rust only", "value": "rust", "description": "Rust + cargo" },
                { "label": "All (Node+Python+Rust+Go)", "value": "all", "description": "Full dev environment" }
            ]
        }
    ],
    "setup_scripts": {
        "desktop": {
            "gnome": [
                "wsl -d SakLinux -- sudo apt update",
                "wsl -d SakLinux -- sudo apt install -y gnome-shell gnome-terminal gnome-tweaks"
            ],
            "kde": [
                "wsl -d SakLinux -- sudo apt update",
                "wsl -d SakLinux -- sudo apt install -y kde-plasma-desktop konsole"
            ],
            "xfce": [
                "wsl -d SakLinux -- sudo apt update",
                "wsl -d SakLinux -- sudo apt install -y xfce4 xfce4-terminal"
            ]
        },
        "install_sakura_pkg": {
            "true": [
                "wsl -d SakLinux -- bash -c 'curl -fsSL https://raw.githubusercontent.com/838288383838383/sakura-package-manager/main/install.sh | bash'"
            ]
        },
        "default_shell": {
            "zsh": [
                "wsl -d SakLinux -- sudo apt install -y zsh",
                "wsl -d SakLinux -- chsh -s /bin/zsh sakura"
            ],
            "fish": [
                "wsl -d SakLinux -- sudo apt install -y fish",
                "wsl -d SakLinux -- chsh -s /usr/bin/fish sakura"
            ]
        },
        "install_languages": {
            "node": [
                "wsl -d SakLinux -- bash -c 'curl -fsSL https://deb.nodesource.com/setup_20.x | sudo -E bash - && sudo apt install -y nodejs'"
            ],
            "python": [
                "wsl -d SakLinux -- bash -c 'sudo apt install -y python3 python3-pip python3-venv'"
            ],
            "rust": [
                "wsl -d SakLinux -- bash -c 'curl --proto \"=https\" --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y'"
            ],
            "all": [
                "wsl -d SakLinux -- bash -c 'curl -fsSL https://deb.nodesource.com/setup_20.x | sudo -E bash - && sudo apt install -y nodejs'",
                "wsl -d SakLinux -- bash -c 'sudo apt install -y python3 python3-pip python3-venv'",
                "wsl -d SakLinux -- bash -c 'curl --proto \"=https\" --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y'",
                "wsl -d SakLinux -- bash -c 'wget -q https://go.dev/dl/go1.22.4.linux-amd64.tar.gz && sudo tar -C /usr/local -xzf go1.22.4.linux-amd64.tar.gz && rm go1.22.4.linux-amd64.tar.gz'"
            ]
        }
    },
    "post_install": [
        "Write-Host ''",
        "Write-Host '  🌸 SakLinux installed!' -ForegroundColor Green",
        "Write-Host ''",
        "Write-Host '  Launch with:' -ForegroundColor Yellow",
        "Write-Host '    saklinux' -ForegroundColor White",
        "Write-Host '    wsl -d SakLinux' -ForegroundColor White",
        "Write-Host ''",
        "Write-Host '  First boot will finalize setup.' -ForegroundColor DarkGray",
        "Write-Host ''"
    ],
    "checkver": {
        "url": "https://github.com/838288383838383/saklinux/releases",
        "regex": "v([\\d.]+)"
    }
}
