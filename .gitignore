# Sakura Package Manager

# User data (don't track)
.sakura/apps/
.sakura/shims/
.sakura/cache/
.sakura/persist/
.sakura/data/
.sakura/pet/
.sakura/config.json

# Separate git repos (tracked in their own repos)
buckets/sakura-community/
buckets/sakura-nerdfonts/
buckets/sakura-nonportable/
buckets/sakura-wsl/

# OS files
Thumbs.db
Desktop.ini
.DS_Store

# Editor files
*.swp
*.swo
*~
.vscode/
.idea/

# Downloaded archives
*.zip
*.7z
*.exe
*.msi

# Temp files
*.tmp
*.log
